<!-- This component defines the help text (button commands) common to all views. -->
<theme>
  <formatVersion>7</formatVersion>
  <view name="system, basic, detailed, grid">
    <helpsystem name="help">
      <origin>0 0</origin>
      <pos>0.01 0.967</pos>
      <fontSize>0.022</fontSize>
      <textColor>${helpTextColor}</textColor>
      <iconColor>${helpIconColor}</iconColor>
      <fontPath>./_inc/fonts/Gilroy-Bold.ttf</fontPath>
      <iconA>./_inc/icons/help-button-east.svg</iconA>
      <iconB>./_inc/icons/help-button-south.svg</iconB>
      <iconX>./_inc/icons/help-button-north.svg</iconX>
      <iconY>./_inc/icons/help-button-west.svg</iconY>
    </helpsystem>
  </view>
  <!--
        The position is changed in "system" view to avoid overlapping with the system panel info
        (only if the resolution is wide enough to allow it and we are not using RetroBat).
    -->
  <view name="system">
    <helpsystem name="help">
      <pos ifSubset="aspect-ratio:16-9|16-9-auto|16-10|16-10-auto">0.48 0.967</pos>
      <pos ifSubset="distribution:retrobat">0.01 0.967</pos>
    </helpsystem>
  </view>
</theme>
